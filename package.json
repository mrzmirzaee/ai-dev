{
  "name": "@mrmamado/ai-dev",
  "version": "2.2.0",
  "description": "Bootstrap any repository for AI coding tools.",
  "type": "module",
  "license": "MIT",
  "author": "mrmamado",
  "homepage": "https://www.npmjs.com/package/@mrmamado/ai-dev",
  "keywords": [
    "ai",
    "ai-coding",
    "agents",
    "cli",
    "developer-tools",
    "scaffolding",
    "claude-code",
    "opencode",
    "codex",
    "cursor",
    "copilot",
    "graphify",
    "mcp"
  ],
  "bin": {
    "ai-dev": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "ai-dev.config.example.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm lint && pnpm test && pnpm build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "execa": "^9.5.1",
    "fs-extra": "^11.2.0",
    "ora": "^8.1.1",
    "prompts": "^2.4.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.9.0",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
